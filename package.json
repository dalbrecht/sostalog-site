{
  "name": "sostalog-site-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Marketing site for sosta (https://sostalog.com)",
  "license": "MIT",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @sostalog/site dev",
    "preview": "pnpm --filter @sostalog/site preview",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @sostalog/site test:e2e",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "ci": "pnpm run typecheck && pnpm run lint && pnpm run format:check && pnpm run test && pnpm run build"
  },
  "devDependencies": {
    "prettier": "3.3.3",
    "prettier-plugin-astro": "0.14.1",
    "typescript": "5.6.2"
  }
}
