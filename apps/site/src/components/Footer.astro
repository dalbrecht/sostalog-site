---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <nav class="footer-sitemap" aria-label="Footer">
    <a href="/">sostalog</a>
    <span class="sep" aria-hidden="true">·</span>
    <a href="/blog">Blog</a>
    <span class="sep" aria-hidden="true">·</span>
    <a href="/changelog">Changelog</a>
  </nav>
  <p class="footer-meta">
    <a href="https://github.com/dalbrecht/sosta/blob/main/LICENSE" rel="noopener">MIT</a>
    <span class="sep" aria-hidden="true">·</span>
    <a href="https://github.com/dalbrecht/sosta" rel="noopener">github.com/dalbrecht/sosta</a>
    <span class="sep" aria-hidden="true">·</span>
    <span>{year}</span>
  </p>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    padding: 2rem 1.5rem;
    text-align: center;
  }

  .footer-sitemap,
  .footer-meta {
    margin: 0;
    color: var(--fg-faint);
    font-size: 0.875rem;
  }

  .footer-sitemap {
    margin-bottom: 0.5rem;
  }

  .footer-sitemap a {
    color: var(--fg-muted);
  }

  .footer-sitemap a:hover,
  .footer-meta a:hover {
    color: var(--fg);
  }

  .sep {
    margin: 0 0.5rem;
    color: var(--border-strong);
  }
</style>
