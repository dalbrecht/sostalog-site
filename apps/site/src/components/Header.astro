---
interface Props {
  currentPath?: string;
}

const { currentPath = Astro.url.pathname } = Astro.props;

const navLinks = [
  { href: '/changelog', label: 'Changelog' },
  // future: { href: '/docs', label: 'Docs' },
  // future: { href: '/blog', label: 'Blog' },
] as const;

const isCurrent = (href: string) => currentPath === href || currentPath === `${href}/`;
---

<header class="site-header">
  <a class="wordmark" href="/" aria-label="sostalog home">sostalog</a>
  <nav class="site-nav" aria-label="Main">
    {
      navLinks.map((link, i) => (
        <>
          {i > 0 && (
            <span class="sep" aria-hidden="true">
              ·
            </span>
          )}
          <a
            href={link.href}
            class={isCurrent(link.href) ? 'is-current' : undefined}
            aria-current={isCurrent(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        </>
      ))
    }
  </nav>
  <a class="github-link" href="https://github.com/dalbrecht/sosta" rel="noopener" aria-label="View sosta on GitHub">
    GitHub <span aria-hidden="true">↗</span>
  </a>
</header>

<style>
  .site-header {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
    padding: 1.25rem 1.5rem;
    max-width: 64rem;
    margin: 0 auto;
    width: 100%;
  }

  .wordmark {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--fg);
  }

  .site-nav {
    flex: 1 1 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    font-size: 0.875rem;
  }

  .site-nav a {
    color: var(--fg-muted);
  }

  .site-nav a:hover {
    color: var(--fg);
  }

  .site-nav a.is-current {
    color: var(--fg);
    font-weight: 500;
  }

  .site-nav .sep {
    margin: 0 0.5rem;
    color: var(--border-strong);
  }

  .github-link {
    font-size: 0.875rem;
    color: var(--fg-muted);
  }

  .github-link:hover {
    color: var(--fg);
  }

  @media (max-width: 640px) {
    .site-header {
      gap: var(--space-2);
    }
    .site-nav {
      width: 100%;
      order: 3;
      justify-content: flex-start;
    }
    .github-link {
      margin-left: auto;
    }
  }
</style>
