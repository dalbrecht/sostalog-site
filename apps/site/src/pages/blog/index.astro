---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

// BlogData mirrors the zod schema in `apps/site/sagegrouse.config.ts`.
// Sagegrouse-astro doesn't yet bridge the zod schema's TypeScript types
// through Astro's content collection, so we cast manually. If you add or
// rename a field in the sagegrouse schema, update this interface in lockstep
// and the content-schema vitest test (`tests/content-schema.test.ts`) will
// catch shape drift at the runtime schema layer.
interface BlogData {
  title: string;
  date: Date;
  summary: string;
}

const rawPosts = await getCollection('blog');
const posts = (rawPosts as Array<(typeof rawPosts)[number] & { data: BlogData }>).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

// Date formatting convention matches /changelog: render the UTC date portion.
// All posts use a frontmatter date-only string (e.g., `date: 2026-05-20`)
// which Astro parses as midnight UTC; the UTC slice matches the author intent.
function formatDate(d: Date): string {
  return d.toISOString().slice(0, 10);
}
---

<Base title="Blog — sostalog" description="Notes on journaling, attention, and building sosta. Newest first.">
  <link slot="head" rel="alternate" type="application/rss+xml" title="sostalog blog" href="/blog/rss.xml" />
  <Header currentPath="/blog" />
  <main class="blog">
    <header class="blog-header">
      <h1>Blog</h1>
      <p class="lede">Notes on journaling, attention, and building sosta. Newest first.</p>
    </header>
    <ul class="post-list">
      {
        posts.map((post) => (
          <li>
            <a href={`/blog/${post.id}/`}>
              <h2>{post.data.title}</h2>
              <p class="meta">
                <time datetime={formatDate(post.data.date)}>{formatDate(post.data.date)}</time>
              </p>
              <p class="summary">{post.data.summary}</p>
            </a>
          </li>
        ))
      }
    </ul>
  </main>
  <Footer />
</Base>

<style>
  .blog {
    max-width: 42rem;
    margin: 0 auto;
    padding: 6rem 1.5rem 4rem;
  }

  .blog-header {
    margin-bottom: var(--space-7);
  }

  .blog-header h1 {
    font-family: var(--font-serif);
    font-size: 2.5rem;
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin: 0 0 0.5rem;
    color: var(--fg);
  }

  .lede {
    margin: 0;
    color: var(--fg-muted);
    font-size: 1rem;
  }

  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .post-list li {
    margin-bottom: var(--space-6);
  }

  .post-list a {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .post-list a:hover h2 {
    color: var(--accent);
  }

  .post-list h2 {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
    color: var(--fg);
  }

  .meta {
    margin: 0 0 0.75rem;
    color: var(--fg-faint);
    font-size: 0.875rem;
  }

  .summary {
    margin: 0;
    font-size: 1.0625rem;
    color: var(--fg-muted);
    line-height: 1.55;
  }

  @media (max-width: 640px) {
    .blog {
      padding: 3rem 1.5rem;
    }
    .blog-header {
      margin-bottom: var(--space-6);
    }
  }
</style>
