---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

// BlogData mirrors the zod schema in `apps/site/sagegrouse.config.ts`.
// See the note in `src/pages/blog/index.astro` — sagegrouse-astro doesn't
// bridge the zod types yet, so we cast manually and lean on the
// content-schema vitest test to catch shape drift.
interface BlogData {
  title: string;
  date: Date;
  summary: string;
}

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

type Props = { post: Awaited<ReturnType<typeof getCollection<'blog'>>>[number] };
const { post } = Astro.props;
const data = post.data as BlogData;
const { Content } = await render(post);

function formatDate(d: Date): string {
  return d.toISOString().slice(0, 10);
}
---

<Base
  title={`${data.title} — sostalog`}
  description={data.summary}
  ogType="article"
  publishedTime={data.date.toISOString()}
>
  <link slot="head" rel="alternate" type="application/rss+xml" title="sostalog blog" href="/blog/rss.xml" />
  <Header currentPath="/blog" />
  <main class="post">
    <p class="back"><a href="/blog">← Blog</a></p>
    <article>
      <header class="post-header">
        <h1>{data.title}</h1>
        <p class="meta">
          <time datetime={formatDate(data.date)}>{formatDate(data.date)}</time>
        </p>
        <p class="summary">{data.summary}</p>
      </header>
      <div class="body">
        <Content />
      </div>
    </article>
  </main>
  <Footer />
</Base>

<style>
  .post {
    max-width: 42rem;
    margin: 0 auto;
    padding: 4rem 1.5rem;
  }

  .back {
    margin: 0 0 2rem;
    font-size: 0.875rem;
  }

  .back a {
    color: var(--fg-muted);
  }

  .back a:hover {
    color: var(--fg);
  }

  .post-header {
    margin-bottom: var(--space-6);
  }

  .post-header h1 {
    font-family: var(--font-serif);
    font-size: 2.25rem;
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin: 0 0 0.5rem;
    color: var(--fg);
  }

  .meta {
    margin: 0 0 1rem;
    color: var(--fg-faint);
    font-size: 0.875rem;
  }

  .summary {
    margin: 0;
    font-size: 1.0625rem;
    font-weight: 500;
    color: var(--fg);
    line-height: 1.55;
  }

  .body {
    color: var(--fg);
    line-height: 1.7;
    font-size: 1.0625rem;
  }

  .body :global(h3) {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 600;
    margin: 2rem 0 0.75rem;
    color: var(--fg);
  }

  .body :global(p) {
    margin: 0 0 1.25rem;
  }

  .body :global(ul) {
    padding-left: 1.25rem;
    margin: 0 0 1.25rem;
  }

  .body :global(li) {
    margin: 0.375rem 0;
  }

  .body :global(strong) {
    font-weight: 600;
  }

  .body :global(code) {
    font-family: var(--font-sans);
    color: var(--accent);
  }

  @media (max-width: 640px) {
    .post {
      padding: 3rem 1.5rem;
    }
    .post-header h1 {
      font-size: 1.875rem;
    }
  }
</style>
